# browser-login configuration — all optional.
#
# browser.py reads these from the *process environment* (os.environ), so for the
# ones that affect login you must EXPORT them in your shell (e.g. ~/.zshrc), not
# only place them in a repo .env. Copy to .env for local convenience if you like
# (.env is gitignored). NEVER put secrets here — only names/paths/labels.

# --- claude.ai (anthropic) full-auto magic-link login ---
# Your claude.ai login email. When set AND `himalaya` is configured to read that
# mailbox, `browser.py login anthropic` is fully automatic (no password, no code):
# it triggers the magic-link email, reads it, and opens the link. If unset, login
# falls back to ASSISTED (you complete the email login in the window once).
# Must be EXPORTED in the shell — browser.py reads the live environment.
# ANTHROPIC_LOGIN_EMAIL=you@example.com

# --- shared browser ---
# Chrome DevTools Protocol (CDP) port the shared Chromium listens on (default 9222).
# CLAUDE_BROWSER_CDP_PORT=9222

# --- CSCS (cscs) unattended Keycloak login ---
# 1Password account + item used as the credential fallback (Touch-ID gated) before
# the macOS keychain is populated. Defaults: my.1password.com / "CSCS".
# CSCS_OP_ACCOUNT=my.1password.com
# CSCS_OP_ITEM=CSCS

# macOS-keychain *service-name* labels (NOT secrets) under which `store-creds cscs`
# saves the username / password / TOTP seed. Defaults shown; override only if they
# collide with existing keychain items.
# CSCS_KEYCHAIN_USER=cscs-api: username
# CSCS_KEYCHAIN_PASS=cscs-api: password
# CSCS_KEYCHAIN_TOTP=cscs-api: totp-seed
